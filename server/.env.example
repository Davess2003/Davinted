# --- Stripe backend config ---
# Copy this file to server/.env and fill in your keys (server/.env is gitignored).

# Your Stripe SECRET key (starts with sk_test_ or sk_live_). Never commit this.
STRIPE_SECRET_KEY=

# Port the API listens on (frontend expects 4242 by default — see root .env VITE_API_BASE).
PORT=4242

# Where your Vite frontend runs. Used for CORS + Stripe Connect return links.
CLIENT_URL=http://localhost:5173

# Currency for charges (ISO code, lowercase).
CURRENCY=usd

# --- Supabase backend config ---
# Project URL, e.g. https://xxxx.supabase.co
SUPABASE_URL=
# The SERVICE ROLE key (secret — full DB access, bypasses RLS). Never expose to the browser.
# Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=
